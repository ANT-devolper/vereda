<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme applied before Compose takes over. Dark to match the dark-first app and
         avoid a white flash on launch; the window background is the app's night background. -->
    <style name="Theme.Vereda" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/vereda_background</item>
        <item name="android:statusBarColor">@color/vereda_background</item>
        <item name="android:navigationBarColor">@color/vereda_background</item>
    </style>
</resources>
